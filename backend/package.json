{
  "name": "vedaai-backend",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "description": "Backend for VedaAI Assessment Creator",
  "main": "dist/server.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test-ai": "ts-node-dev --transpile-only src/test_ai.ts",
    "test-pdf": "ts-node-dev --transpile-only src/test_pdf.ts",
    "connect-chrome": "ts-node-dev --transpile-only src/connect_chrome.ts"
  },
  "dependencies": {
    "bullmq": "^5.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "mongoose": "^8.3.1",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "playwright-core": "^1.60.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/pdfkit": "^0.13.4",
    "rimraf": "^5.0.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
